# ============================================================
# PawNest — Root .gitignore
# ============================================================


# ─── Dependency directories ──────────────────────────────────
node_modules/
**/node_modules/


# ─── Environment & Secret Files ──────────────────────────────
# CRITICAL: Never commit .env files — they contain real secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.local
**/.env.*.local
backend/.env
frontend/.env

# .env.example is SAFE to commit (contains no real values)
# So we do NOT ignore it:
!.env.example
!**/.env.example
!backend/.env.example


# ─── Build Artifacts ─────────────────────────────────────────
dist/
**/dist/
build/
**/build/
out/
**/out/


# ─── Local Database (JSON flat files) ────────────────────────
# These are generated at runtime and may contain user PII
backend/data/*.json


# ─── Uploaded Media ──────────────────────────────────────────
backend/uploads/
**/uploads/


# ─── Logs ────────────────────────────────────────────────────
*.log
logs/
**/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# ─── OS / Editor Metadata ────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/settings.json
.idea/


# ─── Testing ─────────────────────────────────────────────────
coverage/
.nyc_output/


# ─── Misc ────────────────────────────────────────────────────
*.tgz
*.tar.gz
.cache/
.temp/
tmp/
