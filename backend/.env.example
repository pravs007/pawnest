# ============================================================
# PawNest — Backend Environment Variables Template
# ============================================================
# Copy this file to .env and fill in all values before running.
#
#   cp .env.example .env
#
# NEVER commit .env to version control.
# .env.example is safe to commit — it contains NO real secrets.
# ============================================================


# ─── Server ──────────────────────────────────────────────────
PORT=5000


# ─── Authentication ──────────────────────────────────────────
# Generate a strong random secret (minimum 32 chars recommended):
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS


# ─── Database ────────────────────────────────────────────────
# Set to 'true' to use local JSON files (no MongoDB needed — good for dev)
# Set to 'false' to connect to a real MongoDB / MongoDB Atlas instance
USE_LOCAL_DB=false

# Required when USE_LOCAL_DB=false
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster.mongodb.net/pawnest


# ─── AI Assistant (Groq) ─────────────────────────────────────
# Get a free key at https://console.groq.com/keys
# Leave blank to run the AI Assistant in mock/fallback mode
GROQ_API_KEY=


# ─── Email (Nodemailer + Gmail SMTP) ─────────────────────────
# Your Gmail address (the one that SENDS emails)
EMAIL_USER=your-gmail@gmail.com

# Gmail App Password — NOT your regular password!
# Steps to generate:
#   1. Enable 2-Step Verification: https://myaccount.google.com/security
#   2. Go to: https://myaccount.google.com/apppasswords
#   3. App: Mail | Device: Other → type "PawNest"
#   4. Copy the 16-character password (no spaces)
EMAIL_APP_PASSWORD=

# Public URL of your app (used in email links)
APP_URL=http://localhost:3000
